# Core
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_BASE_URL=

# Web UI and REST API
NAIMA_API_ADDR=:8080
NAIMA_API_TOKEN=
NAIMA_UI_BASIC_AUTH_USER=
# SHA256 hex digest of the password to type in browser basic auth
NAIMA_UI_BASIC_AUTH_PASS=
DOMAIN=

# Telegram
TELEGRAM_BOT_TOKEN=
NAIMA_TELEGRAM_STREAM=false
NAIMA_SESSION_FILE=.naima_session.json
NAIMA_TRANSCRIPTION_MODEL=whisper-1
NAIMA_TTS_MODEL=tts-1
NAIMA_TTS_VOICE=alloy
NAIMA_TTS_FORMAT=mp3

# Memory and PostgreSQL/pgvector
NAIMA_MEMORY_MAX_CONTEXT=20
NAIMA_MEMORY_SUMMARY_TIMEOUT_MS=8000
NAIMA_PGVECTOR_DSN=postgres://naima:naima@localhost:5432/naima?sslmode=disable
NAIMA_PGVECTOR_SEARCH_LIMIT=5
NAIMA_PGVECTOR_EMBEDDING_DIMS=0

# Personal Knowledge Base
NAIMA_PKB_INGEST_MODE=hybrid
NAIMA_PKB_CHUNK_SIZE=2000
NAIMA_PKB_TAG_LIMIT=12
NAIMA_PKB_RETRIEVAL_DOC_LIMIT=3
NAIMA_PKB_RETRIEVAL_CHUNK_LIMIT=4
NAIMA_PKB_RETRIEVAL_THRESHOLD=0.35
NAIMA_PKB_UPLOAD_DIR=./data/pkb_uploads

# Tool defaults
# Set each tool to enabled or disabled. Empty means enabled by default.
NAIMA_TOOL_TIME=
NAIMA_TOOL_WEATHER=
NAIMA_TOOL_WEB_SEARCH=
NAIMA_TOOL_NEWS_DIGEST=
NAIMA_TOOL_PERSONAL_KNOWLEDGE_BASE=
NAIMA_TOOL_PKB_RETRIEVE=
NAIMA_TOOL_BASH=
NAIMA_TOOL_PLAYWRIGHT=
NAIMA_TOOL_TASK_SCHEDULER=
NAIMA_TOOL_LONG_MEMORY=
NAIMA_TOOL_MEMORY_DUMP=
NAIMA_TOOL_TELEGRAM_SEND=

# External services and tool backends
NAIMA_SEARX_URL=http://localhost:8081
NAIMA_TIKA_URL=http://localhost:9998
NAIMA_TIKA_ALLOW_FALLBACK=true
NAIMA_TIKA_FILE_TIMEOUT_MS=180000
NAIMA_BASH_TOOL_URL=http://localhost:8090
NAIMA_PLAYWRIGHT_HEADLESS=true
NAIMA_PLAYWRIGHT_TIMEOUT_MS=30000

# Scheduling
NAIMA_TASK_TIMEZONE=UTC

# Local paths
NAIMA_UI_DIR=./internal/httpapi/ui
NAIMA_TOOL_PROMPTS_DIR=./internal/tools
